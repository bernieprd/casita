{
  "name": "casita",
  "private": true,
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev:frontend": "pnpm --filter frontend dev",
    "dev:worker": "pnpm --filter worker dev",
    "build": "pnpm -r build",
    "build:frontend": "pnpm --filter frontend build",
    "build:worker": "pnpm --filter worker build",
    "deploy": "pnpm -r run deploy",
    "deploy:frontend": "pnpm --filter frontend run deploy",
    "deploy:worker": "pnpm --filter worker run deploy",
    "typecheck": "pnpm -r typecheck",
    "check": "pnpm typecheck && pnpm build:frontend"
  },
  "engines": {
    "node": ">=22",
    "pnpm": ">=9"
  },
  "devDependencies": {
    "wrangler": "^4.97.0"
  }
}
