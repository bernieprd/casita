{
  "name": "frontend",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "deploy": "pnpm build && wrangler pages deploy dist --project-name=casita-frontend",
    "generate-pwa-assets": "pwa-assets-generator",
    "generate-native-assets": "node scripts/generate-resources.mjs && capacitor-assets generate --iconBackgroundColor '#fef9c3' --iconBackgroundColorDark '#1a1a1a' --splashBackgroundColor '#fef9c3' --splashBackgroundColorDark '#1a1a1a'",
    "sync": "cap sync",
    "android": "cap open android",
    "ios": "cap open ios",
    "cap:build": "pnpm build && cap sync"
  },
  "dependencies": {
    "@capacitor/app": "^8.1.0",
    "@capacitor/core": "^8.4.0",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@clerk/clerk-react": "^5.61.8",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^5.4.0",
    "@tanstack/react-query": "^5.101.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.4.0",
    "lucide-react": "^1.17.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.5.0",
    "react": "^18.3.1",
    "react-day-picker": "^10.0.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.78.0",
    "react-router-dom": "^7.17.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "vaul": "^1.1.2",
    "workbox-window": "^7.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@capacitor/android": "^8.4.0",
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.4.0",
    "@capacitor/ios": "^8.4.0",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/react-query-devtools": "^5.101.0",
    "@types/node": "^25.9.2",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "@vite-pwa/assets-generator": "^1.0.2",
    "@vitejs/plugin-react": "^4.7.0",
    "sharp": "^0.34.5",
    "typescript": "^5.9.3",
    "vite": "^5.4.21",
    "vite-plugin-pwa": "^1.3.0"
  }
}
